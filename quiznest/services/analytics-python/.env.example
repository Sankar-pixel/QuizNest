# services/analytics-python/.env.example
# Copy to .env for local (non-Docker) runs.

MONGO_URI=mongodb://127.0.0.1:27017/quiznest

# Must match backend/.env's INTERNAL_ADMIN_KEY
INTERNAL_ADMIN_KEY=replace-with-a-shared-secret

# --- Question generation: leave all three blank to use the zero-config ---
# --- local template generator. Set ONE provider to use a real model.   ---

# "openai" or "anthropic" — leave blank for template mode
LLM_PROVIDER=

# Only used when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Only used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
