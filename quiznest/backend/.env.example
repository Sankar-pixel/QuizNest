# Copy this file to `.env` and fill in real values. Never commit `.env`.

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/quiznest

# Secret used to sign JWTs — use a long, random string in production
JWT_SECRET=replace-with-a-long-random-secret

# Port the Express API listens on
PORT=4000

# URL of the Python analytics/question-generation service
ANALYTICS_URL=http://localhost:8000

# Shared secret with the analytics service's /generate-questions route.
# Must match INTERNAL_ADMIN_KEY in services/analytics-python's environment.
INTERNAL_ADMIN_KEY=replace-with-a-shared-secret
